    <item>
      <title>快速打开命令行工具</title>
      <link>https://example.com/programming/win10/%E5%BF%AB%E9%80%9F%E6%89%93%E5%BC%80%E5%91%BD%E4%BB%A4%E8%A1%8C%E5%B7%A5%E5%85%B7/index.html</link>
